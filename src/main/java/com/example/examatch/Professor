import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.Table;

@Entity
@Table(name = "professores")
public class Professor extends Usuario {

    @Column(nullable = false)
    private String departamento;
     public Professor() {
    }

  
    public String getDepartamento() {
        return departamento;
    }

    public void setDepartamento(String departamento) {
        this.departamento = departamento;
    }

    
    public void visualizarRelatorioAluno(Aluno aluno) {
         System.out.println("Gerando relatório para o aluno: " + aluno.getNome());
    }

    public void visualizarRelatorioTurma(Disciplina disciplina) {
         System.out.println("Gerando relatório para a disciplina: " + disciplina.getNome());
    }
}